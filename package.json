{
  "name": "xiaofeng-blog",
  "private": true,
  "license": "MIT",
  "repository": "https://github.com/XiaofengXie16/xiaofeng-blog.git",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "deploy": "fly deploy --remote-only",
    "build": "vp build",
    "dev": "vp dev",
    "lint": "vp lint",
    "start": "bun ./scripts/start-server.ts",
    "typecheck": "tsgo",
    "format": "vp fmt .",
    "format:check": "vp fmt --check .",
    "prepare": "vp config",
    "postinstall": "node -e \"const{rmSync,symlinkSync,lstatSync,existsSync}=require('fs');const v='node_modules/vite';if(existsSync(v)&&!lstatSync(v).isSymbolicLink()){rmSync(v,{recursive:true});symlinkSync('@voidzero-dev/vite-plus-core',v)}\"",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:coverage": "vp test run --coverage",
    "analyze": "vite-bundle-analyzer dist/"
  },
  "dependencies": {
    "@ai-sdk/groq": "^3.0.29",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-start": "^1.166.16",
    "ai": "^6.0.116",
    "gray-matter": "^4.0.3",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tiny-invariant": "^1.3.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@rolldown/plugin-babel": "^0.2.1",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260317.1",
    "@vitejs/plugin-react": "6",
    "@vitest/coverage-v8": "4.1.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "baseline-browser-mapping": "^2.10.8",
    "bun-types": "^1.3.10",
    "jsdom": "^29.0.0",
    "typescript": "^5.9.3",
    "vite-bundle-analyzer": "^1.3.6",
    "vite-plus": "latest"
  },
  "optionalDependencies": {
    "@oxlint/linux-x64-gnu": "^1.43.0",
    "@rollup/rollup-linux-x64-gnu": "^4.59.0",
    "lightningcss-linux-x64-gnu": "^1.32.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "bun@1.3.9"
}
